<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlay_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="#E6121214"
    android:elevation="12dp"
    android:padding="0dp">

    <LinearLayout
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 拖动条 -->
        <LinearLayout
            android:id="@+id/overlay_drag_bar"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:background="#E6162D"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="任务控制台"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/overlay_btn_close"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="6dp"
                android:text="关闭"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/overlay_log_scroll"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:fillViewport="true"
            android:padding="8dp">

            <TextView
                android:id="@+id/overlay_log_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:lineSpacingExtra="2dp"
                android:text="等待任务…"
                android:textColor="#E0E0E0"
                android:textSize="11sp" />
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp">

            <Button
                android:id="@+id/overlay_btn_stop"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:backgroundTint="#C62828"
                android:text="停止任务"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

            <Button
                android:id="@+id/overlay_btn_dump"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:backgroundTint="#1565C0"
                android:text="dump节点"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">

            <Button
                android:id="@+id/overlay_btn_clear"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:backgroundTint="#455A64"
                android:text="清除日志"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
